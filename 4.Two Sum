class Solution {
    public int[] twoSum(int[] nums, int target) {
        int l=nums.length;
        HashMap<Integer,Integer>map=new HashMap<>();
        int[] arr=new int[2];
        for(int i=0;i<l;i++){
          map.put(nums[i],i);

        }
        for(int i=0;i<l;i++){
            if(map.containsKey(target-nums[i]) && map.get(target-nums[i])!=i){
                arr[1]=map.get(target-nums[i]);
                arr[0]=i;
                return arr;
            }
        }
        return arr;
    }
}
